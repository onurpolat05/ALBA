# ALBA .gitignore

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key
credentials.*

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Node (if MCP servers are installed locally)
node_modules/
package-lock.json

# Claude Code local settings
.claude/settings.local.json

# ALBA runtime logs (auto-generated by hooks)
memory/knowledge/errors_raw.log
